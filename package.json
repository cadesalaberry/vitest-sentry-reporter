{
  "name": "vitest-sentry-reporter",
  "version": "1.0.1",
  "description": "Vitest reporter that sends failures and context to Sentry.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun build --target=node --format=esm --packages=external --outdir=dist src/index.ts && bun run build:types",
    "build:types": "tsc --emitDeclarationOnly",
    "prepublishOnly": "bun run build",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:dogfood": "DOGFOOD=true bun run test run",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "validate:pr-title": "bun run scripts/validate-pr-title.ts",
    "validate:commit-msg": "bun run scripts/validate-commit-msg.ts",
    "prepare": "lefthook install || true"
  },
  "keywords": [
    "vitest",
    "reporter",
    "sentry",
    "testing",
    "ci"
  ],
  "author": "C-A de Salaberry",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cadesalaberry/vitest-sentry-reporter.git"
  },
  "homepage": "https://github.com/cadesalaberry/vitest-sentry-reporter#readme",
  "bugs": {
    "url": "https://github.com/cadesalaberry/vitest-sentry-reporter/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18",
    "bun": ">=1.1.0"
  },
  "packageManager": "bun@1.2.21",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@sentry/node": ">=10.0.0",
    "vitest": ">=3.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@sentry/node": "^10.27.0",
    "@types/node": "^18",
    "@vitest/coverage-v8": "^4.0.13",
    "lefthook": "^2.1.9",
    "typescript": "^6.0.3",
    "vitest": "^4.0.13"
  }
}
